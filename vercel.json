{
  "version": 2,
  "builds": [
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$",              "dest": "/public/html/index.html"    },
    { "src": "^/html/(.*)$",     "dest": "/public/html/$1"            },
    { "src": "^/css/(.*)$",      "dest": "/public/css/$1"             },
    { "src": "^/images/(.*)$",   "dest": "/public/images/$1"          }
  ]
}
